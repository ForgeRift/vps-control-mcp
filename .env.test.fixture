# Copy to .env.test and run scripts/prepare-test-env.mjs before use
APP_DIR=/tmp/testapp
PM2_LOG_DIR=/tmp/pm2logs
AUDIT_LOG_PATH=__REPLACE_ME__
PORT=3001
ALLOWED_UNITS=nginx,my-api
# deploy_client enabled in tests so the wired executeTool path is covered.
# Absolute path; under /var so it doubles as proof the generic cp-to-system-dir
# guardrail still blocks ad-hoc `cp` here while the dedicated tool is allowed.
CLIENT_WEB_ROOT=/var/www/servicecycle/html
