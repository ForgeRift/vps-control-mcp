# ── Required ──────────────────────────────────────────────────────────────────
# Generate a strong random token and keep this private.
# The setup script generates this automatically. To generate manually:
#   openssl rand -hex 32
MCP_AUTH_TOKEN=replace-with-a-strong-random-token

# ── Optional (defaults shown) ─────────────────────────────────────────────────
PORT=3001

# Path to your application directory (the app PM2 manages alongside this server)
APP_DIR=/root/your-app

# PM2 log directory
PM2_LOG_DIR=/root/.pm2/logs

# Audit log location
AUDIT_LOG_PATH=/root/mcp-audit.log

# Comma-separated list of PM2 process names this server is allowed to manage
# Example: ALLOWED_PROCESSES=my-api,my-worker
ALLOWED_PROCESSES=

# Comma-separated systemd units `journalctl -u <unit>` may read. journalctl always
# requires an explicit -u naming one of these — there is no system-wide dump.
# Defaults (if unset) to the ServiceCycle web/TLS/auth-guard set:
#   nginx.service,certbot.service,certbot.timer,sc-auth-guard.service,sc-auth-guard.timer
# Set this to override that list entirely.
# ALLOWED_UNITS=

# ── Read-only diagnostic directories ──────────────────────────────────────────
# Added to the read allowlist alongside APP_DIR and PM2_LOG_DIR so nginx config and
# host logs can be read via cat/grep/tail. READ surface only — no write path is
# opened, and the credential-name blocks (*.key, *.pem, .htpasswd, *password*,
# *token*, *credentials*) still apply to files inside these directories.
# Defaults shown:
# NGINX_CONF_DIR=/etc/nginx
# HOST_LOG_DIR=/var/log

# ── deploy_client (opt-in) ────────────────────────────────────────────────────
# Set CLIENT_WEB_ROOT to enable the deploy_client tool, which builds the client
# container and publishes its compiled dist/ into this FIXED nginx web root.
# Empty = tool disabled. The destination is ALWAYS CLIENT_WEB_ROOT and is never
# taken from caller input — that is what makes it safe to allow. Must be absolute.
# Example: CLIENT_WEB_ROOT=/var/www/servicecycle/html
CLIENT_WEB_ROOT=
# Optional overrides (defaults shown):
# CLIENT_COMPOSE_FILE=/root/ServiceCycle/docker-compose.yml
# CLIENT_SERVICE=client
# CLIENT_DIST_PATH=/app/dist

# ── ServiceCycle app-operations tools (always on) ─────────────────────────────
# get_app_status / get_app_logs / migrate_status / reseed_demo / restart_app all
# operate on this FIXED docker-compose project. The path is never caller-supplied;
# each tool's service argument is a strict enum. Override only if your droplet
# stores the compose file elsewhere. Default shown:
# COMPOSE_FILE=/root/ServiceCycle/docker-compose.yml

# Max escape-hatch commands per session (resets on server restart).
# Set to 999999 to effectively remove the cap (Dustin preference — use env var, not source edits).
MAX_CUSTOM_COMMANDS_PER_SESSION=10

# Required for BLOCKED-tier AI classification (Layer 2 + Layer 3)
ANTHROPIC_API_KEY=your-anthropic-api-key
